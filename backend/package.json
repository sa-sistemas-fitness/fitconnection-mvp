{
  "name": "fitconnection-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "API de FitConnection",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "build": "npm run prisma:generate",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=prisma/schema.prisma",
    "prisma:seed": "node prisma/seed.js",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma",
    "prisma:generate:postgres": "prisma generate --schema=prisma/schema.postgresql.prisma",
    "prisma:migrate:postgres": "prisma migrate deploy --schema=prisma/schema.postgresql.prisma"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcrypt": "6.0.0",
    "cors": "2.8.5",
    "dotenv": "16.6.1",
    "express": "5.1.0",
    "jsonwebtoken": "9.0.2",
    "nodemailer": "^9.0.1",
    "prisma": "6.19.3"
  },
  "devDependencies": {
    "nodemon": "3.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
